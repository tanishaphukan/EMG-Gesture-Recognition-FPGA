# Vivado generated project folder (regenerate using scripts/create_vivado_project.tcl)
vivado_project/

# Vivado logs and journals
*.jou
*.log
*.str
*.backup.jou
*.backup.log

# Vivado cache and temp
.Xil/
*.wdb

# Synthesis and implementation outputs (large binary files, not needed in repo)
*.dcp
*.bit
*.bin
*.ltx
*.mcs

# Simulation outputs
xsim.dir/
*.vcd
*.lx2

# IP files
*.xci
*.xco
ip_user_files/

# Reports (regenerated by Vivado — do not commit)
*.rpt
*.rpx

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Python (for model training)
__pycache__/
*.pyc
*.pyo
.env/
venv/
.ipynb_checkpoints/
